# Copy to .env and fill in. .env is git-ignored and is used ONLY on your machine,
# only during provisioning — credentials never reach the ESP32 or any artifact.
HOMEWHIZ_USER=you@example.com
HOMEWHIZ_PASS=your-homewhiz-password

# Optional: pick a specific appliance (otherwise you're prompted / auto-selected
# when the account has exactly one). Set at most one.
# HOMEWHIZ_MODEL=EWUE7636XAW
# HOMEWHIZ_APPLIANCE_ID=

# Optional: localization language for entity labels (default en-GB).
# HOMEWHIZ_LANGUAGE=en-GB
