# Copy to secrets.yaml (git-ignored) and fill in. Never commit secrets.yaml.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# The appliance's BLE MAC. Unknown? Flash bridge.yaml as-is and read it from the
# [scan] logs (HomeWhiz devices advertise a name starting "HwZ_").
appliance_mac: "AA:BB:CC:DD:EE:FF"

# Optional static IP (see bridge.yaml). Only needed if you keep the `manual_ip`
# block — delete that block for DHCP and you can drop these three.
static_ip: "192.168.1.50"
gateway: "192.168.1.1"
subnet: "255.255.255.0"
